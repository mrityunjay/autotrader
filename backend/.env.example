# Angel One SmartAPI Credentials
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_password_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# Trading Configuration
TRADING_CAPITAL=50000          # Total capital in INR
MAX_POSITIONS=5                # Max concurrent open positions
POSITION_SIZE_PCT=0.20         # 20% of capital per position
STOP_LOSS_PCT=0.02             # 2% stop loss
TARGET_PCT=0.045               # 4.5% profit target
TRAILING_SL_PCT=0.02           # 2% trailing stop loss
TOP_STOCKS_TO_SCORE=50         # Score top N Nifty 200 stocks each morning

# Market Hours (IST)
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
SQUARE_OFF_TIME=15:10          # Force close all positions before this time
SCORING_TIME=09:05             # Run scorer before market open

# App Config
DATABASE_URL=sqlite+aiosqlite:///./trading.db
LOG_LEVEL=INFO
ENVIRONMENT=production
